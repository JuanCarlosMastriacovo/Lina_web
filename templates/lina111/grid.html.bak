<table class="table table-sm table-hover table-sticky m-0">
	<thead>
		<tr>
			<th class="ps-3" style="cursor:pointer" hx-get="/clients/list?sort=cliecodi" :hx-target="'#' + $id('wgrid')">Código</th>
			<th style="cursor:pointer" hx-get="/clients/list?sort=cliename" :hx-target="'#' + $id('wgrid')">Nombre</th>
		</tr>
	</thead>
	<tbody>
		{% for item in clients %}
		<tr class="grid-row detail-nav-trigger" hx-get="/clients/detail/{{ item.cliecodi }}" :hx-target="'#' + $id('wdetail')"
			data-detail-url="/clients/detail/{{ item.cliecodi }}"
			data-item-code="{{ item.cliecodi }}"
			data-item-label="{{ item.cliename }}"
			@click="selectedIndex = {{ loop.index0 }}; updateSelection()"
			@focus="selectedIndex = {{ loop.index0 }}; updateSelection()"
			@keydown.enter.prevent="$el.click()"
			@keydown.numpad-enter.prevent="$el.click()"
			tabindex="0">
			<td class="ps-3">{{ item.cliecodi }}</td>
			<td>{{ item.cliename }}</td>
		</tr>
		{% else %}
		<tr class="grid-empty">
			<td class="ps-3" colspan="2">Sin registros para mostrar.</td>
		</tr>
		{% endfor %}
	</tbody>
</table>
